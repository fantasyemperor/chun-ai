# 配置模板：复制为 application-local.yml 并填入真实密钥（该文件已加入 .gitignore）
# 或直接使用环境变量，见项目根目录 README.md
#
#   cp src/main/resources/application.yml.example src/main/resources/application-local.yml
#   export SPRING_PROFILES_ACTIVE=local
#
# 环境变量（无需 local 文件）：
#   SPRING_AI_DASHSCOPE_API_KEY   -> spring.ai.dashscope.api-key
#   SEARCH_API_API_KEY            -> search-api.api-key
#   SPRING_AI_VECTORSTORE_QDRANT_HOST / PORT  -> Qdrant 连接

server:
  port: 8888

spring:
  application:
    name: chun-ai
  ai:
    dashscope:
      # 阿里云 DashScope：https://dashscope.console.aliyun.com/
      api-key: your-dashscope-api-key
      embedding:
        options:
          model: text-embedding-v4
      chat:
        options:
          model: qwen3-max
    vectorstore:
      qdrant:
        host: localhost
        port: 6334            # gRPC 端口
        use-tls: false
        # api-key:            # 本地无鉴权可不填；云端 Qdrant 需配置
        collection-name: chun_ai
        initialize-schema: true

# Agent 联网搜索：https://www.searchapi.io/
search-api:
  api-key: your-searchapi-api-key
